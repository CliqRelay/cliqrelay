# Example environment variables for the API service. Copy this file to .env and fill in the values.
REDIS_URL=
EVENT_BUS_CONSUMER_GROUP=cliqrelay-consumer-group

S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PRESIGNED_URL_EXPIRY=15m

SMTP_HOST=
SMTP_PORT=

# Follow the Authula docs here: https://authula.vercel.app/docs/get-started/installation
AUTHULA_BASE_URL=
AUTHULA_SECRET=

# OpenAPI spec version (defaults to "0.1.0" if not set)
OPENAPI_SPEC_VERSION=0.1.0
CLIENT_URL=
EXTENSION_URL=
DATABASE_URL=
STANDALONE_MODE=true
BASE_URL=http://localhost:8080
PORT=8080
GO_ENV=development
LOG_LEVEL=debug
